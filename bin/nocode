#!/usr/bin/env bash
# NoCode Agent - TUI launcher
# Usage: nocode [--resume]

# 自动定位项目目录（支持软链接）
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_PATH/.." && pwd)"
TUI_PATH="$PROJECT_DIR/nocode_agent/frontend/tui.ts"

export ZHIPU_API_KEY="${ZHIPU_API_KEY:-$(cat ~/.config/nocode/api_key 2>/dev/null || echo '')}"
export NOCODE_API_KEY="${NOCODE_API_KEY:-${OLLAMA_API_KEY:-${OPENAI_API_KEY:-${ZHIPU_API_KEY}}}}"

if [ -z "$NOCODE_API_KEY" ] && [ -z "${NOCODE_AGENT_CONFIG:-}" ]; then
    echo "Warning: no API key detected."
    echo "  If you use Ollama, set NOCODE_AGENT_CONFIG to an Ollama config file"
    echo "  Or export one of: NOCODE_API_KEY / OPENAI_API_KEY / OLLAMA_API_KEY / ZHIPU_API_KEY"
fi

cd "$PROJECT_DIR"
exec node --experimental-strip-types "$TUI_PATH" "$@"
